<Window x:Class="StaleDeviceManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Stale Device Manager" Height="760" Width="1180"
        WindowStartupLocation="CenterScreen" FontFamily="Segoe UI" FontSize="13">

    <DockPanel Margin="10">

        <!-- Header / flow -->
        <Border DockPanel.Dock="Top" Background="#0F3D5C" CornerRadius="6" Padding="14,10" Margin="0,0,0,10">
            <Grid>
                <StackPanel>
                    <TextBlock Text="Stale Device Manager" Foreground="White" FontSize="20" FontWeight="SemiBold"/>
                    <TextBlock Foreground="#BFD8E8" Margin="0,2,0,0"
                               Text="Flow:  1. Scan  →  2. Review &amp; select  →  3. Disable  →  (wait)  →  4. Delete"/>
                </StackPanel>
                <Button x:Name="BtnAbout" Content="About" Width="80" Height="28"
                        HorizontalAlignment="Right" VerticalAlignment="Top" Click="BtnAbout_Click"/>
            </Grid>
        </Border>

        <!-- Controls -->
        <Border DockPanel.Dock="Top" BorderBrush="#DDD" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,18,0">
                    <TextBlock Text="Inactive days:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox x:Name="DaysBox" Text="90" Width="60" VerticalContentAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Center" Margin="0,0,18,0">
                    <CheckBox x:Name="ChkAd" Content="On-prem AD" IsChecked="True" Margin="0,0,0,4"/>
                    <CheckBox x:Name="ChkEntra" Content="Entra ID" IsChecked="True" Margin="0,0,0,4"/>
                    <CheckBox x:Name="ChkIntune" Content="Intune (MDM)" IsChecked="True"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Vertical" VerticalAlignment="Center" Margin="0,0,18,0">
                    <CheckBox x:Name="ChkExcludeServers" Content="Exclude servers" Margin="0,0,0,4"/>
                    <TextBlock x:Name="EntraStatus" Text="Entra: not connected" Foreground="#A33" FontSize="11"/>
                </StackPanel>

                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="BtnConnectEntra" Content="Connect Entra…" Width="120" Height="30" Margin="0,0,8,0" Click="BtnConnectEntra_Click"/>
                    <Button x:Name="BtnScan" Content="Scan" Width="90" Height="30" Click="BtnScan_Click"
                            Background="#0F6CBD" Foreground="White" FontWeight="SemiBold"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Credentials (optional) -->
        <Expander DockPanel.Dock="Top" Header="Credentials (optional - leave blank to use the signed-in Windows user)"
                  IsExpanded="False" Margin="0,0,0,10">
            <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,6,0,0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="On-prem AD" Width="86" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        <TextBlock Text="User:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBox x:Name="AdUser" Width="180" Margin="0,0,12,0" VerticalContentAlignment="Center"
                                 ToolTip="DOMAIN\user or user@domain. Leave blank to use the current Windows user."/>
                        <TextBlock Text="Password:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <PasswordBox x:Name="AdPass" Width="150" Margin="0,0,12,0" VerticalContentAlignment="Center"/>
                        <TextBlock Text="Domain/DC:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBox x:Name="AdServer" Width="170" VerticalContentAlignment="Center"
                                 ToolTip="Optional. e.g. corp.local or dc01.corp.local. Leave blank for the current domain."/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Entra / Intune" Width="86" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        <TextBlock Text="Sign in as:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBox x:Name="EntraUpn" Width="240" Margin="0,0,12,0" VerticalContentAlignment="Center"
                                 ToolTip="UPN of the admin account to sign in as, e.g. cleanup-admin@contoso.com"/>
                        <TextBlock Text="(you complete sign-in, including MFA, in the browser)"
                                   Foreground="#777" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Expander>

        <!-- Action bar + log (bottom) -->
        <Border DockPanel.Dock="Bottom" BorderBrush="#DDD" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,10,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="120"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                    <Button x:Name="BtnSelectAll" Content="Select all" Width="90" Height="30" Margin="0,0,8,0" Click="BtnSelectAll_Click"/>
                    <Button x:Name="BtnSelectNone" Content="Clear" Width="70" Height="30" Margin="0,0,18,0" Click="BtnSelectNone_Click"/>
                    <Button x:Name="BtnDisable" Content="Disable selected" Width="140" Height="30" Margin="0,0,8,0" Click="BtnDisable_Click"
                            Background="#C98A00" Foreground="White" FontWeight="SemiBold"/>
                    <Button x:Name="BtnDelete" Content="Delete selected" Width="140" Height="30" Click="BtnDelete_Click"
                            Background="#B12A2A" Foreground="White" FontWeight="SemiBold"/>
                    <TextBlock x:Name="SelectionInfo" VerticalAlignment="Center" Margin="18,0,0,0" Foreground="#555"/>
                </StackPanel>

                <TextBox x:Name="LogBox" Grid.Row="1" IsReadOnly="True" FontFamily="Consolas" FontSize="12"
                         VerticalScrollBarVisibility="Auto" TextWrapping="NoWrap" Background="#1E1E1E" Foreground="#DDD"/>
            </Grid>
        </Border>

        <!-- Filter / export bar -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
            <TextBlock Text="Filter OS:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <ComboBox x:Name="OsFilter" Width="240" SelectionChanged="OsFilter_SelectionChanged"/>
            <Button x:Name="BtnExportCsv" Content="Export CSV" Width="110" Height="28" Margin="14,0,0,0" Click="BtnExportCsv_Click"/>
            <Button x:Name="BtnOpenAudit" Content="Open audit log" Width="120" Height="28" Margin="8,0,0,0" Click="BtnOpenAudit_Click"/>
            <TextBlock x:Name="FilterInfo" VerticalAlignment="Center" Margin="14,0,0,0" Foreground="#555"/>
        </StackPanel>

        <!-- Results grid -->
        <DataGrid x:Name="Grid" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="False"
                  GridLinesVisibility="Horizontal" HeadersVisibility="Column" SelectionMode="Extended"
                  AlternatingRowBackground="#F5F8FB">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Binding="{Binding Selected, UpdateSourceTrigger=PropertyChanged}" Width="40">
                    <DataGridCheckBoxColumn.Header>
                        <CheckBox x:Name="HeaderSelectAll" ToolTip="Select / clear all shown"
                                  Checked="HeaderSelectAll_Changed" Unchecked="HeaderSelectAll_Changed"/>
                    </DataGridCheckBoxColumn.Header>
                </DataGridCheckBoxColumn>
                <DataGridTextColumn Header="Source" Binding="{Binding SourceLabel}" Width="90" IsReadOnly="True"/>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="180" IsReadOnly="True"/>
                <DataGridCheckBoxColumn Header="Enabled" Binding="{Binding Enabled}" Width="62" IsReadOnly="True"/>
                <DataGridTextColumn Header="Last user" Binding="{Binding LastUser}" Width="170" IsReadOnly="True"/>
                <DataGridTextColumn Header="Last activity" Binding="{Binding LastActivity, StringFormat=yyyy-MM-dd}" Width="95" IsReadOnly="True"/>
                <DataGridTextColumn Header="Pwd last set" Binding="{Binding PasswordLastSet, StringFormat=yyyy-MM-dd}" Width="95" IsReadOnly="True"/>
                <DataGridTextColumn Header="Created" Binding="{Binding WhenCreated, StringFormat=yyyy-MM-dd}" Width="90" IsReadOnly="True"/>
                <DataGridTextColumn Header="Reason" Binding="{Binding Reason}" Width="170" IsReadOnly="True"/>
                <DataGridTextColumn Header="OS" Binding="{Binding OperatingSystem}" Width="130" IsReadOnly="True"/>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*" IsReadOnly="True"/>
            </DataGrid.Columns>
        </DataGrid>

    </DockPanel>
</Window>
