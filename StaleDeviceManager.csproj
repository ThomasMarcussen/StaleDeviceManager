<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net9.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <LangVersion>latest</LangVersion>
    <AssemblyName>StaleDeviceManager</AssemblyName>
    <RootNamespace>StaleDeviceManager</RootNamespace>
    <ApplicationIcon>icon.ico</ApplicationIcon>
    <Version>1.3.0</Version>
    <Company>ThomasMarcussen.com</Company>
    <Product>Stale Device Manager</Product>
    <Authors>Thomas Marcussen</Authors>
    <Copyright>© 2026 ThomasMarcussen.com</Copyright>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Graph" Version="5.56.0" />
    <PackageReference Include="Azure.Identity" Version="1.13.1" />
    <PackageReference Include="System.DirectoryServices" Version="9.0.0" />
    <PackageReference Include="System.DirectoryServices.AccountManagement" Version="9.0.0" />
  </ItemGroup>

</Project>
